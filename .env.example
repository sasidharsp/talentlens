# ─── TalentLens Environment Variables ───
# Copy this file to .env and fill in your values

# Database (auto-set by docker-compose — only override for local dev)
DATABASE_URL=postgresql://postgres:talentlens@localhost:5432/talentlens

# Security — CHANGE THIS in production!
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars

# Anthropic API key — required for Segment 3 LLM evaluation
ANTHROPIC_API_KEY=sk-ant-...

# App
ENVIRONMENT=production
FRONTEND_URL=http://localhost

# Email (optional — for future notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
